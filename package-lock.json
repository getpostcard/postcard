{
  "name": "postcard",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "postcard",
      "version": "0.0.0",
      "workspaces": [
        "clients/apps/*",
        "clients/shared/*"
      ],
      "engines": {
        "node": ">=22"
      }
    },
    "clients/apps/console": {
      "name": "@postcard/console",
      "version": "0.0.0"
    },
    "clients/apps/setup": {
      "name": "@postcard/setup",
      "version": "0.0.0"
    },
    "clients/apps/studio": {
      "name": "@postcard/studio",
      "version": "0.0.0"
    },
    "clients/shared/protocol": {
      "name": "@postcard/protocol",
      "version": "0.0.0"
    },
    "clients/shared/render": {
      "name": "@postcard/render",
      "version": "0.0.0"
    },
    "node_modules/@postcard/console": {
      "resolved": "clients/apps/console",
      "link": true
    },
    "node_modules/@postcard/protocol": {
      "resolved": "clients/shared/protocol",
      "link": true
    },
    "node_modules/@postcard/render": {
      "resolved": "clients/shared/render",
      "link": true
    },
    "node_modules/@postcard/setup": {
      "resolved": "clients/apps/setup",
      "link": true
    },
    "node_modules/@postcard/studio": {
      "resolved": "clients/apps/studio",
      "link": true
    }
  }
}
